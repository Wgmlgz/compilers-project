// Basic ArrowRust test file

// Variable declarations
let x = 5;
let mut y = 10;
let z: i32 = 15;
let flag: bool = true;
let message: str = "Hello, ArrowRust!";

// Assignment to mutable variable
y = y + 5;

// Compound assignment
y += 2;

// Conditional logic
if flag {
    print!("Flag is true!");
} else {
    print!("Flag is false!");
}

// Simple if
if x < y {
    print!("x is less than y");
}

// Block expression
let result = {
    let a = 5;
    let b = a * 2;
    b + 1  // No semicolon = return value
};

print!("Result is: {}", result);

// While loop
let mut count = 0;
while count < 5 {
    print!("Count: {}", count);
    count += 1;
}

print!("Final count: {}", count); 